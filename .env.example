# Nudgly – copy to .env and fill in for local development.
# Used by Docker Compose and by backend/frontend when run locally.

# --- Backend (Django) ---
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL). Docker Compose uses postgres/redis services.
DATABASE_URL=postgres://nudgly:nudgly@localhost:5432/nudgly

# Redis (for health check and future Celery).
REDIS_URL=redis://localhost:6379/0

# Email sender adapter: "stdout" logs to app logger (dev/test). Other values (e.g. sendgrid) when adapters exist.
# EMAIL_SENDER=stdout

# Frontend origin for password-reset and OAuth callback redirects.
# Local Vite dev: http://localhost:5173. Docker (nginx on 9000): http://localhost:9000
# FRONTEND_ORIGIN=http://localhost:5173

# OAuth (required for "Sign in with Google" / "Sign in with Apple"). Set in .env; Docker Compose passes them to the backend.
# Google: create OAuth 2.0 credentials in Google Cloud Console (APIs & Services → Credentials). Use "Web application", add Authorized redirect URI: https://<your-host>/api/auth/oauth/google/login/callback/ (or http://localhost:9000/... for local).
# Apple: create a Services ID in Apple Developer (Certificates, Identifiers & Profiles → Identifiers), enable "Sign in with Apple", and configure the redirect URL to match.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# CORS: comma-separated origins, or set CORS_ALLOW_ALL_ORIGINS=true for local dev only.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1
# CORS_ALLOW_ALL_ORIGINS=true

# --- Docker Compose (Postgres/Redis) ---
POSTGRES_USER=nudgly
POSTGRES_PASSWORD=nudgly
POSTGRES_DB=nudgly

# --- Frontend (Vite) ---
# API base URL at build time. Use empty string when served behind nginx (same-origin).
# For local dev with Vite dev server, use http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000
