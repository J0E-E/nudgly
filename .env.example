# Nudgly – copy to .env and fill in for local development.
# Used by Docker Compose and by backend/frontend when run locally.

# --- Backend (Django) ---
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL). Docker Compose uses postgres/redis services.
DATABASE_URL=postgres://nudgly:nudgly@localhost:5432/nudgly

# Redis (for health check and future Celery).
REDIS_URL=redis://localhost:6379/0

# Email sender adapter: "stdout" logs to app logger (dev/test). Other values (e.g. sendgrid) when adapters exist.
# EMAIL_SENDER=stdout

# Frontend origin for password-reset links (e.g. http://localhost:5173 or production app URL).
# FRONTEND_ORIGIN=http://localhost:5173

# CORS: comma-separated origins, or set CORS_ALLOW_ALL_ORIGINS=true for local dev only.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1
# CORS_ALLOW_ALL_ORIGINS=true

# --- Docker Compose (Postgres/Redis) ---
POSTGRES_USER=nudgly
POSTGRES_PASSWORD=nudgly
POSTGRES_DB=nudgly

# --- Frontend (Vite) ---
# API base URL at build time. Use empty string when served behind nginx (same-origin).
# For local dev with Vite dev server, use http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000
